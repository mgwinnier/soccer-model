# Copy this file to ".env" (same folder) and fill in your keys.
# The app auto-loads .env on startup — no system env vars needed.

# API-Football (https://www.api-football.com) — confirmed lineups + injuries
API_FOOTBALL_KEY=your_api_football_key_here

# Kaggle — FIFA player ratings. Two ways (pick ONE):
#   (a) env vars here: your Kaggle USERNAME + the API token (the "key"):
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_token
#   (b) OR drop the downloaded kaggle.json into  secrets/kaggle.json  (no vars needed)
# Note: a lone token works as KAGGLE_KEY, but the CLI still needs KAGGLE_USERNAME.

# Optional: The Odds API fallback (not needed — ESPN odds are used by default)
# ODDS_API_KEY=your_the_odds_api_key_here
